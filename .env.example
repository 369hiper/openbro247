# OpenBro247 Configuration Template
# Copy this file to .env and fill in your actual values

# ========================================
# AI PROVIDER API KEYS
# ========================================

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local LLM Configuration (for Ollama or other local models)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# Default LLM Provider (openai, anthropic, or local)
DEFAULT_LLM_PROVIDER=openai

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server host and port
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# ========================================
# MEMORY SYSTEM CONFIGURATION
# ========================================

# Vector database path (ChromaDB)
VECTOR_PATH=./data/memory/vectors

# SQLite database path
SQLITE_PATH=./data/memory/structured.db

# ========================================
# BROWSER CONFIGURATION
# ========================================

# Browser settings
BROWSER_HEADLESS=false
BROWSER_TYPE=chromium
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# Human-like behavior settings
BROWSER_HUMAN_LIKE=true
BROWSER_SPEED_MULTIPLIER=1.0
BROWSER_TIMEOUT=30000
BROWSER_SLOW_MO=50

# ========================================
# LOGGING CONFIGURATION
# ========================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ========================================
# INTEGRATION API KEYS (Optional)
# ========================================

# YouTube API (for advanced features)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google APIs (for various integrations)
GOOGLE_API_KEY=your_google_api_key_here

# ========================================
# SHILERGY MARKETING PLUGIN
# ========================================

# Gemini API key — used for Imagen image generation
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Blotato API key — used to publish posts to social platforms
# Get one at: https://blotato.com/
BLOTATO_API_KEY=your_blotato_api_key_here

# imgbb API key — free image host, gives public URLs for Blotato mediaUrls
# Get one at: https://api.imgbb.com/ (free tier sufficient)
IMGBB_API_KEY=your_imgbb_api_key_here

# Timezone for cron scheduling (default: Asia/Kolkata = IST)
MARKETING_TIMEZONE=Asia/Kolkata

# Optional: webhook URL to notify when a draft is ready for approval
# e.g. a Slack incoming webhook or n8n webhook
MARKETING_APPROVAL_WEBHOOK=

# Optional: override local directory for generated images
# Default: ./data/marketing/images
# MARKETING_IMAGES_DIR=./data/marketing/images

# ========================================
# ADVANCED CONFIGURATION
# ========================================

# Memory limits
MAX_MEMORIES=100000
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Skill learning settings
AUTO_EXTRACT_SKILLS=true
MIN_CONFIDENCE=0.7
MAX_SKILLS=1000

# Crawler settings
MAX_DEPTH=3
MAX_PAGES=100
CRAWLER_DELAY=1000
RESPECT_ROBOTS=true