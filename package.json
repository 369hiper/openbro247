{
  "name": "openbro247-typescript",
  "version": "1.0.0",
  "description": "AI-powered browser automation system with semantic memory and MCP integration",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "openbro247": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-esm src/main.ts",
    "clean": "rimraf dist coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "install-playwright": "playwright install chromium"
  },
  "keywords": [
    "ai",
    "browser-automation",
    "playwright",
    "typescript",
    "semantic-memory",
    "mcp",
    "llm",
    "desktop-automation",
    "vision-ai",
    "agent"
  ],
  "author": "OpenBro247 Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openbro247/openbro247-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/openbro247/openbro247-typescript/issues"
  },
  "homepage": "https://github.com/openbro247/openbro247-typescript#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^0.4.0",
    "better-sqlite3": "^12.8.0",
    "chromadb": "^3.4.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "openai": "^6.32.0",
    "playwright": "^1.58.2",
    "uuid": "^10.0.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.0",
    "tweetnacl": "^1.0.3",
    "jsonwebtoken": "^9.0.0",
    "youtubei.js": "^10.0.0"
  },
  "optionalDependencies": {
    "playwright-chromium": "^1.58.2"
  }
}
